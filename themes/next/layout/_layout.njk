      z-index: 99999; /* 超高层级，确保覆盖所有内容 */
      margin: 0;
      padding: 0;
      line-height: 1.5;
    }
    /* 为“醒悟”单独设置样式，区分字体大小 */
    .ip-block-layer .wake-up {
