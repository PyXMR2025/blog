<body 
  itemscope 
  itemtype="http://schema.org/WebPage"
  {% if theme.motion.enable %} class="use-motion"{% endif %}
>
  <!-- 顶部装饰条 -->
  <div class="headband"></div>

  <!-- 页面主体 -->
  <main class="main">
    <div class="column">
      <!-- 页面头部 -->
      <header class="header" itemscope itemtype="http://schema.org/WPHeader">
        {%- include '_partials/header/index.njk' -%}
      </header>
      
      <!-- 侧边栏（可配置） -->
      {%- if theme.sidebar.display !== 'remove' %}
        {% block sidebar %}{% endblock %}
      {%- endif %}
    </div>

    <div class="main-inner {% block class %}{% endblock %}">
      <!-- 子菜单 -->
      {%- include '_partials/header/sub-menu.njk' -%}
      <!-- 页面核心内容（模板块） -->
      {% block content %}{% endblock %}
      <!-- 评论区 -->
      {%- include '_partials/comments.njk' -%}
    </div>
  </main>

  <!-- 页脚 -->
  <footer class="footer">
    <div class="footer-inner">
      <!-- 多语言切换 -->
      {%- include '_partials/languages.njk' -%}
      
      <!-- 页脚公共内容（缓存控制） -->
      {{ partial('_partials/footer.njk', {}, {cache: theme.cache.enable}) }}

      <!-- SVG徽章容器 -->
      <div class="license-badges">
        <!-- CC BY-NC-SA 徽章 + 跳转链接 -->
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer">
          <img src="https://s4.zstatic.net/ajax/libs/creativecommons-vocabulary/2020.11.3/assets/license_badges/big/by_nc_sa.svg" alt="CC BY-NC-SA 许可证">
        </a>
        <!-- Not by AI 徽章 + 跳转链接 -->
        <a href="https://notbyai.fyi/cn/" target="_blank" rel="noopener noreferrer">
          <img src="/img/favicon/not-by-ai-white.svg" alt="Not by AI">
        </a>
      </div>
        
      <!-- 运行时长统计展示行 -->
      <div class="uptime-row">
        本站已经稳定运行了 
        <span class="uptime-num" id="days">00</span> 天 
        <span class="uptime-num" id="hours">00</span> 小时 
        <span class="uptime-num" id="minutes">00</span> 分钟 
        <span class="uptime-num" id="seconds">00</span> 秒
      </div>

      <!-- 广告脚本（仅保留一次引入） -->
      <!-- <script async="async" data-cfasync="false" src="https://pl28675819.effectivegatecpm.com/0f2aeb03ec930e47193f4782e446c5b6/invoke.js"></script> -->
      <!-- <div id="container-0f2aeb03ec930e47193f4782e446c5b6"></div> -->

    </div>
  </footer>

  <!-- 页面组件（缓存控制） -->
  {{ partial('_partials/widgets.njk', {}, {cache: theme.cache.enable}) }}

  <!-- 框架注入的页面底部内容 -->
  {{- next_inject('bodyEnd') }}

  <!-- 运行时长统计逻辑 -->
  <script>
    // 站点启动时间（GMT+8 2025-12-15 10:47:19）
    const startTime = new Date('2025-12-15T10:47:19+08:00');
    // 缓存DOM元素，避免重复查询
    const uptimeElements = {
      days: document.getElementById('days'),
      hours: document.getElementById('hours'),
      minutes: document.getElementById('minutes'),
      seconds: document.getElementById('seconds')
    };
    // 定时器标识，用于页面卸载时清理
    let uptimeTimer = null;

    /**
     * 数字补零：单位数补0，如 5 → 05
     * @param {number} num 要补零的数字
     * @returns {string} 补零后的字符串
     */
    function padZero(num) {
      return num.toString().padStart(2, '0');
    }

    /**
     * 计算并更新站点运行时长
     */
    function updateUptime() {
      const now = new Date();
      const diffMs = now - startTime;

      // 处理当前时间早于启动时间的边界情况
      if (diffMs < 0) {
        uptimeElements.days.textContent = '00';
        uptimeElements.hours.textContent = '00';
        uptimeElements.minutes.textContent = '00';
        uptimeElements.seconds.textContent = '00';
        return;
      }

      // 时间单位转换（毫秒 -> 天/小时/分钟/秒）
      const totalSeconds = Math.floor(diffMs / 1000);
      const days = Math.floor(totalSeconds / (24 * 60 * 60));
      const remainingSecondsAfterDays = totalSeconds % (24 * 60 * 60);
      const hours = Math.floor(remainingSecondsAfterDays / (60 * 60));
      const remainingSecondsAfterHours = remainingSecondsAfterDays % (60 * 60);
      const minutes = Math.floor(remainingSecondsAfterHours / 60);
      const seconds = remainingSecondsAfterHours % 60;

      // 更新页面显示（补零后）
      uptimeElements.days.textContent = padZero(days);
      uptimeElements.hours.textContent = padZero(hours);
      uptimeElements.minutes.textContent = padZero(minutes);
      uptimeElements.seconds.textContent = padZero(seconds);
    }

    // 初始化执行 + 每秒更新一次
    updateUptime();
    uptimeTimer = setInterval(updateUptime, 1000);

    // 页面卸载时清理定时器，避免内存泄漏
    window.addEventListener('beforeunload', () => {
      clearInterval(uptimeTimer);
    });
  </script>

<!-- ========== 新增：IP检测限制逻辑 ========== -->
<script>
  const BLOCKED_IPS = ['183.221.116.62', '117.172.228.151'];
  
  // 获取用户公网IP的函数
  async function getUserIP() {
    try {
      // 稳定的免费IP查询接口
      const response = await fetch('https://v4.ident.me/');
      if (!response.ok) throw new Error('IP接口请求失败');
      const ip = await response.text();
      // 去除IP前后可能的空格/换行
      return ip.trim();
    } catch (error) {
      console.error('获取IP失败：', error);
      return null; // 失败时返回null，不限制访问
    }
  }

  // 检测IP并处理页面显示
  async function checkIPAndBlock() {
    const userIP = await getUserIP();
    // 匹配目标IP列表中的任意一个时执行限制逻辑
    if (userIP && BLOCKED_IPS.includes(userIP)) {
      // 隐藏所有博客核心内容
      document.querySelector('.main').style.display = 'none';
      document.querySelector('.footer').style.display = 'none';
      document.querySelector('.headband').style.display = 'none';
      
      // 创建全屏提示层
      const blockLayer = document.createElement('div');
      blockLayer.className = 'ip-block-layer';
      blockLayer.innerHTML = '@初一的小**，你浮木呢？打开B站干嘛，死装哥？？？**的，一天访问2-3次，你当网站是你家呀？@全班同学，他就是个死装哥，密码是因为女同学觉得他太猥琐然后给他的，纯沙子！我**还得给你封了是吧？？？F*** --正在犯恶心的Jackie（我最讨厌死装哥和猥琐男了！），备注：我同学特别反感你！别来我们班了！有事让朱ZE给我说！';
      // 添加到页面
      document.body.appendChild(blockLayer);
    }
  }

  // 页面加载完成后执行检测（确保DOM元素已加载）
  window.addEventListener('load', checkIPAndBlock);
</script>
</body>
